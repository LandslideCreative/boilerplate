{
    "name": "landslidecreative/ls-boilerplate-wp",
    "authors": [
        {
            "name": "Landslide Creative",
            "email": "info@landslidecreative.com"
        }
    ],
    "repositories" : [
        {
            "type" : "composer",
            "url"  : "https://wpackagist.org"
        },
        {
            "type":"composer",
            "url":"https://connect.advancedcustomfields.com"
        },
        {
           "type" : "vcs",
           "url" : "git@github.com:jsjenkins/backup-backup-pro.git"
        },
        {
            "type": "composer",
            "url": "https://composer.gravity.io"
        },        
        {
           "type" : "vcs",
           "url" : "git@github.com:jsjenkins/events-calendar-pro.git"
        },
        {
            "type":"composer",
            "url":"https://composer.deliciousbrains.com"
        }
    ],
    "extra" : {
        "installer-paths" : {
            "wp-content/plugins/{$name}/" : ["type:wordpress-plugin"],
            "wp-content/themes/{$name}/" : ["type:wordpress-theme"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable" : true,
    "require": {
        "wpengine/advanced-custom-fields-pro": "6.8.6",
        "wpackagist-plugin/akismet" : "5.7",
        "wpackagist-plugin/backup-backup" : "2.1.6",
        "landslidecreative/backup-backup-pro" : "2.1.6",
        "wpackagist-plugin/classic-editor" : "1.7.0",
        "gravity/gravityforms": "2.10.5",
        "gravity/gravityformsakismet": "1.1.0",
        "wpackagist-plugin/imagify" : "2.3.0",
        "wpackagist-plugin/intuitive-custom-post-order" : "3.2.0",
        "wpackagist-plugin/query-monitor" : "4.0.7",
        "wpackagist-plugin/safe-redirect-manager" : "2.2.2",
        "wpackagist-plugin/svg-support" : "2.5.17",
        "wpackagist-plugin/the-events-calendar" : "6.17.0",
        "landslidecreative/events-calendar-pro" : "7.8.0",
        "wpackagist-plugin/user-switching" : "1.12.1",
        "wpackagist-plugin/wordfence" : "8.2.2",
        "wpackagist-plugin/wp-crontrol" : "1.21.0",
        "deliciousbrains-plugin/wp-migrate-db-pro": "2.7.10",
        "wpackagist-plugin/yet-another-related-posts-plugin" : "5.30.11",
        "wpackagist-plugin/duplicate-post" : "4.7",
        "wpackagist-plugin/wordpress-seo" : "28.0"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
