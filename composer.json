{
    "name": "landslidecreative/ls-boilerplate-wp",
    "authors": [
        {
            "name": "Landslide Creative",
            "email": "info@landslidecreative.com"
        }
    ],
    "repositories" : [
        {
            "type" : "composer",
            "url"  : "https://wpackagist.org"
        },
        {
            "type":"composer",
            "url":"https://connect.advancedcustomfields.com"
        },
        {
            "type": "composer",
            "url": "https://composer.gravity.io"
        },        
        {
            "type": "package",
            "package": {
                "name": "the-events-calendar/events-calendar-pro",
                "version": "7.7.13",
                "type": "wordpress-plugin",
                "dist": {
                    "url": "https://evnt.is/fetch-ecp?key=c4fee8a87aa0447ac0b7ae88398e2c32a7648238&amp;version=7.7.13",
                    "type": "zip"
                }
            }
        },
        {
            "type":"composer",
            "url":"https://composer.deliciousbrains.com"
        },
        {
            "type" : "vcs",
            "url" : "git@github.com:jsjenkins/wp-rocket.git"
        }
    ],
    "extra" : {
        "installer-paths" : {
            "wp-content/plugins/{$name}/" : ["type:wordpress-plugin"],
            "wp-content/themes/{$name}/" : ["type:wordpress-theme"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable" : true,
    "require": {
        "wpengine/advanced-custom-fields-pro": "6.7.1",
        "wpackagist-plugin/akismet" : "5.6",
        "wpackagist-plugin/classic-editor" : "1.6.7",
        "gravity/gravityforms": "2.9.28",
        "gravity/gravityformsakismet": "1.1.0",
        "wpackagist-plugin/imagify" : "2.2.7",
        "wpackagist-plugin/intuitive-custom-post-order" : "3.2.0",
        "wpackagist-plugin/query-monitor" : "3.20.2",
        "wpackagist-plugin/safe-redirect-manager" : "2.2.2",
        "wpackagist-plugin/svg-support" : "2.5.14",
        "wpackagist-plugin/the-events-calendar" : "6.15.17",
        "the-events-calendar/events-calendar-pro": "*",
        "wpackagist-plugin/user-switching" : "1.11.2",
        "wpackagist-plugin/wordfence" : "8.1.4",
        "wpackagist-plugin/wp-crontrol" : "1.21.0",
        "deliciousbrains-plugin/wp-migrate-db-pro": "2.7.7",
        "wp-media/wp-rocket" : "3.20.3",
        "wpackagist-plugin/yet-another-related-posts-plugin" : "5.30.11",
        "wpackagist-plugin/duplicate-post" : "4.5",
        "wpackagist-plugin/wordpress-seo" : "27.1.1"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
